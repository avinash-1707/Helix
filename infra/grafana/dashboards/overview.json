{
  "uid": "helix-overview",
  "title": "Helix — Overview",
  "tags": ["helix"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total LLM Calls",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "helix-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS calls FROM inference_logs WHERE $__timeFilter(request_at)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2 },
            { "color": "red", "value": 5 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "helix-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 100.0 * count(*) FILTER (WHERE status = 'error') / NULLIF(count(*), 0) AS error_rate FROM inference_logs WHERE $__timeFilter(request_at)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "helix-postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT percentile_cont(0.95) WITHIN GROUP (ORDER BY latency_ms) AS p95 FROM inference_logs WHERE $__timeFilter(request_at) AND status = 'success'"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Call Volume",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "helix-postgres" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(request_at, $__interval), status AS metric, count(*) AS calls FROM inference_logs WHERE $__timeFilter(request_at) GROUP BY 1, status ORDER BY 1"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency Percentiles (success calls)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "helix-postgres" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(request_at, $__interval), percentile_cont(0.5) WITHIN GROUP (ORDER BY latency_ms) AS p50, percentile_cont(0.95) WITHIN GROUP (ORDER BY latency_ms) AS p95, percentile_cont(0.99) WITHIN GROUP (ORDER BY latency_ms) AS p99 FROM inference_logs WHERE $__timeFilter(request_at) AND status = 'success' GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Token Throughput",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "helix-postgres" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(request_at, $__interval), sum(prompt_tokens) AS prompt_tokens, sum(completion_tokens) AS completion_tokens FROM inference_logs WHERE $__timeFilter(request_at) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Ingestion Pipeline (rate/s)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "rate(helix_ingestion_messages_consumed_total[5m])",
          "legendFormat": "consumed"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "rate(helix_ingestion_logs_written_total[5m])",
          "legendFormat": "written"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "sum(rate(helix_ingestion_dlq_total[5m]))",
          "legendFormat": "dlq"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "API HTTP Requests by Status (rate/s)",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "helix-prometheus" },
          "expr": "sum by (status) (rate(helix_api_http_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
