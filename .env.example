# Helix — environment variables. Copy to .env and fill in.
# All values are validated at startup with Zod (see code-standards.md).

# PostgreSQL (TimescaleDB extension enabled)
DATABASE_URL=postgres://helix:helix@localhost:5432/helix

# Redis — conversation context cache + rate limiting
REDIS_URL=redis://localhost:6379

# Redpanda (Kafka-compatible) broker list
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_LOGS=llm.inference.logs
KAFKA_TOPIC_DLQ=llm.inference.dlq

# LLM provider API keys — injected via env only, never stored in DB
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# API gateway
API_PORT=3001
# Trailing messages sent to the model per turn (context window)
CONTEXT_WINDOW_SIZE=10
# Per-session rate limit: max mutating requests per sliding window
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_SEC=60
# Upper bound on a single LLM stream before the gateway abandons it
LLM_REQUEST_TIMEOUT_MS=60000

# Ingestion service
INGESTION_PORT=3002
KAFKA_CONSUMER_GROUP=helix-ingestion

# Web → API base URL
NEXT_PUBLIC_API_URL=http://localhost:3001
